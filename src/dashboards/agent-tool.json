{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Agent and tool execution metrics for MCP-based systems",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (mcp_tool_name) (rate(mcp_tool_call_count[5m]))",
          "legendFormat": "{{mcp_tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Call Volume",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(rate(mcp_tool_call_count{mcp_tool_result_status=\"success\"}[5m])) / sum(rate(mcp_tool_call_count[5m]))",
          "refId": "A"
        }
      ],
      "title": "Overall Tool Success Rate",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (mcp_tool_name) (rate(mcp_tool_call_count{mcp_tool_result_status=\"success\"}[5m])) / sum by (mcp_tool_name) (rate(mcp_tool_call_count[5m]))",
          "legendFormat": "{{mcp_tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Success Rate by Tool",
      "type": "bargauge"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.95, sum by (le, mcp_tool_name) (rate(mcp_tool_call_duration_bucket[5m])))",
          "legendFormat": "{{mcp_tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (mcp_tool_result_status) (rate(mcp_tool_call_count{mcp_tool_result_status!=\"success\"}[5m]))",
          "legendFormat": "{{mcp_tool_result_status}}",
          "refId": "A"
        }
      ],
      "title": "Tool Errors by Type",
      "type": "piechart"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "value": 1, "text": "Up" },
            { "type": "value", "value": 0, "text": "Down" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "mcp_server_up",
          "legendFormat": "{{mcp_server_name}}",
          "refId": "A"
        }
      ],
      "title": "MCP Server Status",
      "type": "stat"
    }
  ],
  "refresh": "1h",
  "schemaVersion": 39,
  "tags": ["mcp-observability", "agent", "tool"],
  "templating": {
    "list": [
      {
        "current": { "text": "AMP", "value": "prometheus" },
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "datasource": "${datasource}",
        "name": "cluster",
        "query": "label_values(cluster)",
        "type": "query"
      },
      {
        "datasource": "${datasource}",
        "name": "namespace",
        "query": "label_values(namespace)",
        "type": "query"
      },
      {
        "datasource": "${datasource}",
        "name": "environment",
        "query": "label_values(environment)",
        "type": "query"
      },
      {
        "datasource": "${datasource}",
        "name": "tool_name",
        "query": "label_values(mcp_tool_name)",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Agent/Tool",
  "uid": "mcp-agent-tool",
  "version": 0,
  "weekStart": ""
}
