# Copy to .env and customize for local development
# cp examples/standalone/.env.example examples/standalone/.env

# OpenTelemetry Collector endpoints
ENV=local
CLUSTER_NAME=docker-compose

# Phoenix trace backend (optional)
PHOENIX_OTLP_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PROJECT_NAME=mcp-local

# Langfuse trace backend (optional)
LANGFUSE_OTLP_ENDPOINT=http://langfuse.observability:8080/api/public/otel
LANGFUSE_API_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse.observability:3000

# AWS Managed Prometheus (optional, for cloud export)
AMP_WORKSPACE_ID=ws-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AMP_REMOTE_WRITE_ENDPOINT=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxx/api/v1/remote_write
AWS_REGION=us-east-1

# CloudWatch Logs (optional, for cloud export)
LOG_GROUP_NAME=/mcp/observability
LOG_STREAM_NAME=otel-collector
